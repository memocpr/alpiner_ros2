<?xml version="1.0"?>
<robot name="komatsu" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include base robot model -->
    <xacro:include filename="$(find robot_description)/urdf/komatsu/komatsu.urdf.xacro"/>

    <!-- ===== Gazebo Material Properties ===== -->
    <gazebo reference="rear_chassis">
        <material>Gazebo/Red</material>
        <mu1>0.5</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <gazebo reference="front_chassis">
        <material>Gazebo/Green</material>
        <mu1>0.5</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <!-- Wheel friction properties -->
    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>4e6</kp>
        <kd>100.0</kd>
    </gazebo>

    <gazebo reference="rear_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>4e6</kp>
        <kd>100.0</kd>
    </gazebo>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>4e6</kp>
        <kd>100.0</kd>
    </gazebo>

    <gazebo reference="front_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>4e6</kp>
        <kd>100.0</kd>
    </gazebo>

    <!-- ===== Sensors ===== -->
    <!-- LiDAR sensor plugin -->
    <gazebo reference="laser_frame">
        <sensor name="laser_sensor" type="ray">
            <always_on>true</always_on>
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.3</min>
                    <max>50.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
            <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>laser_frame</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- IMU sensor plugin -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
                <ros>
                    <remapping>~/out:=imu/data</remapping>
                </ros>
                <initial_orientation_as_reference>true</initial_orientation_as_reference>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ===== Differential Drive Plugin for Simplified Motion ===== -->
    <!-- This plugin provides a simple differential drive interface for cmd_vel -->
    <gazebo>
        <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
                <remapping>/cmd_vel:=/cmd_vel_ll</remapping>
            </ros>

            <!-- Wheels -->
            <left_joint>rear_left_wheel_joint</left_joint>
            <right_joint>rear_right_wheel_joint</right_joint>

            <!-- Kinematics -->
            <wheel_separation>2.160</wheel_separation>
            <wheel_diameter>1.6</wheel_diameter>

            <!-- Limits -->
            <max_wheel_torque>80000</max_wheel_torque>
            <max_wheel_acceleration>20.0</max_wheel_acceleration>

            <!-- Output -->
            <publish_odom>true</publish_odom>
            <publish_odom_tf>false</publish_odom_tf>
            <publish_wheel_tf>false</publish_wheel_tf>
            <!-- Keep /odom consistent with Gazebo world pose to match GNSS motion. -->
            <odometrySource>world</odometrySource>

            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>base_footprint</robot_base_frame>

            <!-- Topics -->
            <command_topic>cmd_vel_ll</command_topic>
            <odometry_topic>odom</odometry_topic>

            <!-- Update rate -->
            <update_rate>50.0</update_rate>
        </plugin>
    </gazebo>

    <!-- Ground-truth p3d plugin removed from default bringup to avoid invalid-link errors. -->

    <!-- ===== GPS / NavSat Plugin ===== -->
    <gazebo reference="gnss_link">
        <sensor name="gnss_sensor" type="gps">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <plugin name="gps_plugin" filename="libgazebo_ros_gps_sensor.so">
                <ros>
                    <remapping>~/out:=gps/fix</remapping>
                </ros>
                <frame_name>gnss_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ===== Joint State Publisher Plugin ===== -->
    <gazebo>
        <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
            <ros>
                <namespace>/</namespace>
            </ros>
            <update_rate>50.0</update_rate>
            <joint_name>rear_left_wheel_joint</joint_name>
            <joint_name>rear_right_wheel_joint</joint_name>
            <joint_name>front_left_wheel_joint</joint_name>
            <joint_name>front_right_wheel_joint</joint_name>
            <joint_name>articulation_to_front</joint_name>
        </plugin>
    </gazebo>

</robot>


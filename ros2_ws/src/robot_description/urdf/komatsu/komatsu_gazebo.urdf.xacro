<?xml version="1.0"?>
<robot name="komatsu" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include base robot model -->
    <xacro:include filename="$(find robot_description)/urdf/komatsu/komatsu.urdf.xacro"/>

    <!-- ===== Gazebo Material Properties ===== -->
    <gazebo reference="rear_chassis">
        <material>Gazebo/Red</material>
        <mu1>0.5</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <gazebo reference="front_chassis">
        <material>Gazebo/Green</material>
        <mu1>0.5</mu1>
        <mu2>0.5</mu2>
    </gazebo>

    <!-- Wheel friction properties -->
    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.6</mu1>
        <mu2>0.6</mu2>
        <kp>1e5</kp>
        <kd>10.0</kd>
    </gazebo>

    <gazebo reference="rear_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.6</mu1>
        <mu2>0.6</mu2>
        <kp>1e5</kp>
        <kd>10.0</kd>
    </gazebo>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.6</mu1>
        <mu2>0.6</mu2>
        <kp>1e5</kp>
        <kd>10.0</kd>
    </gazebo>

    <gazebo reference="front_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>0.6</mu1>
        <mu2>0.6</mu2>
        <kp>1e5</kp>
        <kd>10.0</kd>
    </gazebo>

    <!-- ===== Sensors ===== -->
    <!-- LiDAR sensor plugin -->
    <gazebo reference="laser_frame">
        <sensor name="laser_sensor" type="ray">
            <always_on>true</always_on>
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.3</min>
                    <max>50.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
            <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>laser_frame</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- IMU sensor plugin -->
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
                <ros>
                    <remapping>~/out:=imu/data</remapping>
                </ros>
                <initial_orientation_as_reference>true</initial_orientation_as_reference>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ros2_control interfaces for articulated drive in Gazebo -->
    <ros2_control name="KomatsuGazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>

        <joint name="rear_left_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="rear_right_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="front_left_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="front_right_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="articulation_to_front">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <parameters>$(find robot_bringup)/config/komatsu_ros2_controllers.yaml</parameters>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
            <ros>
                <namespace>/</namespace>
                <remapping>odom:=/odom</remapping>
            </ros>
            <body_name>base_footprint</body_name>
            <update_rate>50.0</update_rate>
            <gaussian_noise>0.0</gaussian_noise>
        </plugin>
    </gazebo>

    <!-- ===== GPS / NavSat Plugin ===== -->
    <gazebo reference="gnss_link">
        <sensor name="gnss_sensor" type="gps">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <plugin name="gps_plugin" filename="libgazebo_ros_gps_sensor.so">
                <ros>
                    <remapping>~/out:=gps/fix</remapping>
                </ros>
                <frame_name>gnss_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

</robot>


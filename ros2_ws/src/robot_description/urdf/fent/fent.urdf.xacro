<?xml version="1.0"?>
<robot name="fent" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find robot_description)/urdf/fent/common_properties.xacro"/>
    <xacro:include filename="$(find robot_description)/urdf/fent/wheels.xacro"/>

    <material name="grey"><color rgba="0.7 0.7 0.7 1.0"/></material>
    <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
    <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>

    <!-- ===== Dimensions ===== -->
    <xacro:property name="A_len" value="4.119"/>
    <xacro:property name="B_wheelbase" value="2.370"/>
    <xacro:property name="D_width" value="2.186"/>
    <xacro:property name="E_track" value="1.660"/>
    <xacro:property name="F_clearance" value="0.475"/>
    <xacro:property name="H_height" value="2.620"/>
    <xacro:property name="half_wb" value="${B_wheelbase/2.0}"/>
    <xacro:property name="wheel_y" value="${E_track/2.0}"/>

    <xacro:property name="wheel_rad_f" value="0.59"/>
    <xacro:property name="wheel_width_f" value="0.44"/>
    <xacro:property name="front_steer_limit" value="0.7853981634"/>
    <xacro:property name="X_len_f" value="${wheel_rad_f}"/>
    <xacro:property name="box_len_f" value="${X_len_f + half_wb}"/>
    <xacro:property name="box_width_f" value="0.50"/>
    <xacro:property name="box_height_f" value="1.30"/>

    <xacro:property name="wheel_rad_r" value="0.78"/>
    <xacro:property name="wheel_width_r" value="0.54"/>
    <xacro:property name="X_len_r" value="0.20"/>
    <xacro:property name="box_len_r" value="${X_len_r + half_wb}"/>
    <xacro:property name="box_width_r" value="${D_width-(2*wheel_width_r)}"/>
    <xacro:property name="box_height_r" value="${H_height-F_clearance}"/>

    <xacro:property name="body_weight" value="1890"/>
    <xacro:property name="wheel_weight_f" value="100"/>
    <xacro:property name="wheel_weight_r" value="150"/>
    <xacro:property name="total_weight" value="${2*(body_weight + wheel_weight_f + wheel_weight_r)}"/>

    <xacro:property name="front_chassis_z_offset" value="${wheel_rad_f - wheel_rad_r}"/>
    <xacro:property name="rear_body_center_z" value="${F_clearance + box_height_r/2.0 - wheel_rad_r}"/>
    <xacro:property name="rear_body_top_z" value="${rear_body_center_z + box_height_r/2.0}"/>
    <xacro:property name="front_body_center_z" value="${F_clearance + box_height_f/2.0 - wheel_rad_f}"/>
    <xacro:property name="front_body_top_z" value="${front_body_center_z + box_height_f/2.0}"/>

    <link name="base_footprint"/>

    <link name="base_link"/>
    <joint name="base_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_rad_r}" rpy="0 0 0"/>
    </joint>

    <joint name="base_to_rear_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_chassis"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="rear_chassis">
        <visual>
            <origin xyz="${-box_len_r/2.0} 0 ${rear_body_center_z}"/>
            <geometry><box size="${box_len_r} ${box_width_r} ${box_height_r}"/></geometry>
            <material name="red"/>
        </visual>

        <collision>
            <origin xyz="${-box_len_r/2.0} 0 ${rear_body_center_z}"/>
            <geometry><box size="${box_len_r} ${box_width_r} ${box_height_r}"/></geometry>
        </collision>

        <xacro:box_inertia
                m="${body_weight}"
                x="${box_len_r}"
                y="${box_width_r}"
                z="${box_height_r}"
                o_xyz="${-box_len_r/2.0} 0 ${rear_body_center_z}"
                o_rpy="0 0 0"/>
    </link>

    <link name="front_chassis">
        <visual>
            <origin xyz="${box_len_f/2.0} 0 ${front_body_center_z}"/>
            <geometry><box size="${box_len_f} ${box_width_f} ${box_height_f}"/></geometry>
            <material name="green"/>
        </visual>

        <collision>
            <origin xyz="${box_len_f/2.0} 0 ${front_body_center_z}"/>
            <geometry><box size="${box_len_f} ${box_width_f} ${box_height_f}"/></geometry>
        </collision>

        <xacro:box_inertia
                m="${body_weight}"
                x="${box_len_f}"
                y="${box_width_f}"
                z="${box_height_f}"
                o_xyz="${box_len_f/2.0} 0 ${front_body_center_z}"
                o_rpy="0 0 0"/>
    </link>

    <joint name="rear_to_front_joint" type="fixed">
        <parent link="rear_chassis"/>
        <child link="front_chassis"/>
        <origin xyz="0 0 ${front_chassis_z_offset}" rpy="0 0 0"/>
    </joint>

    <!-- ===== Wheels ===== -->
    <xacro:wheel name="rear_left_wheel"  parent="rear_chassis"  x="${-half_wb}" y="${ wheel_y}" z="0.0" radius="${wheel_rad_r}" width="${wheel_width_r}" mass="${wheel_weight_r}"/>
    <xacro:wheel name="rear_right_wheel" parent="rear_chassis"  x="${-half_wb}" y="${-wheel_y}" z="0.0" radius="${wheel_rad_r}" width="${wheel_width_r}" mass="${wheel_weight_r}"/>

    <xacro:steerable_wheel name="front_left_wheel"  parent="front_chassis" x="${ half_wb}" y="${ wheel_y}" z="0.0" radius="${wheel_rad_f}" width="${wheel_width_f}" mass="${wheel_weight_f}" steer_limit="${front_steer_limit}"/>
    <xacro:steerable_wheel name="front_right_wheel" parent="front_chassis" x="${ half_wb}" y="${-wheel_y}" z="0.0" radius="${wheel_rad_f}" width="${wheel_width_f}" mass="${wheel_weight_f}" steer_limit="${front_steer_limit}" mimic_joint="front_left_wheel_steer_joint"/>


    <!-- ===== Sensors ===== -->
    <link name="laser_frame"/>
    <joint name="laser_joint" type="fixed">
        <parent link="rear_chassis"/>
        <child link="laser_frame"/>
        <origin xyz="0.0 0.0 ${rear_body_top_z + 0.3}" rpy="0 0 0"/>
    </joint>

    <link name="imu_link"/>
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="gnss_link"/>
    <joint name="gnss_joint" type="fixed">
        <parent link="base_link"/>
        <child link="gnss_link"/>
        <origin xyz="-1.0 0.0 2.0" rpy="0 0 0"/>
    </joint>

</robot>

